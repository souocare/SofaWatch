.PHONY: help run test test-verbose lint format check migrate revision current history

PYTHON := python

help:
	@echo "Available commands:"
	@echo "  make run                 Start the FastAPI development server"
	@echo "  make test                Run the test suite"
	@echo "  make test-verbose        Run the test suite with verbose output"
	@echo "  make lint                Run Ruff lint checks"
	@echo "  make format              Format the code with Ruff"
	@echo "  make check               Run formatting checks, linting and tests"
	@echo "  make migrate             Apply all pending Alembic migrations"
	@echo "  make revision MESSAGE=x  Create an autogenerated Alembic migration"
	@echo "  make current             Show the current Alembic revision"
	@echo "  make history             Show Alembic migration history"

run:
	$(PYTHON) -m uvicorn app.main:app --reload

test:
	$(PYTHON) -m pytest

test-verbose:
	$(PYTHON) -m pytest -v

lint:
	$(PYTHON) -m ruff check .

format:
	$(PYTHON) -m ruff format .

check:
	$(PYTHON) -m ruff format --check .
	$(PYTHON) -m ruff check .
	$(PYTHON) -m pytest

migrate:
	$(PYTHON) -m alembic upgrade head

revision:
ifndef MESSAGE
	$(error MESSAGE is required. Example: make revision MESSAGE="create movies table")
endif
	$(PYTHON) -m alembic revision --autogenerate -m "$(MESSAGE)"

current:
	$(PYTHON) -m alembic current

history:
	$(PYTHON) -m alembic history